{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Grimoire",
  "version": "1.0.0",
  "identifier": "com.grimoire.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "panel",
        "title": "Grimoire",
        "url": "/panel.html",
        "width": 384,
        "height": 677,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": true,
        "alwaysOnTop": true,
        "x": 643,
        "y": 156
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://images.uesp.net https://*.uesp.net data:; connect-src 'self' http://127.0.0.1:8111 https://*.uesp.net; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/grimoire-server"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
